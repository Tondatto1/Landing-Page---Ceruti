{
  "entities": {
    "trial_signup": {
      "title": "Trial Signup",
      "description": "Registers a user for the 7-day free trial captured from the chat widget.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique record identifier"
        },
        "name": {
          "type": "string",
          "description": "Full name of the prospect"
        },
        "company": {
          "type": "string",
          "description": "Company name or property"
        },
        "email": {
          "type": "string",
          "description": "Corporate email address"
        },
        "phone": {
          "type": "string",
          "description": "WhatsApp contact number with DDD"
        },
        "agentSelected": {
          "type": "string",
          "description": "The selected agent for the trial"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Submission time"
        }
      },
      "required": ["name", "company", "email", "phone", "agentSelected", "createdAt"]
    }
  },
  "firestore": {
    "trial_signups/{signupId}": {
      "schema": "trial_signup",
      "description": "Collection of prospect trials awaiting activation"
    }
  }
}
